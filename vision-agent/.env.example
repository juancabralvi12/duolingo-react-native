# Stream credentials may also be loaded from the parent repo .env.local.
STREAM_API_KEY=...
STREAM_API_SECRET=...

# Required for OpenAI Realtime.
OPENAI_API_KEY=...

# Optional defaults.
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
VISION_AGENT_TEACHING_LANGUAGE=Spanish
VISION_AGENT_IDLE_TIMEOUT=60
VISION_AGENT_MAX_SESSIONS=4
