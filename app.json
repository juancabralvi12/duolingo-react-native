{
  "expo": {
    "name": "vocalingo",
    "slug": "jsm-testing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vocalingo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.juancabral12.jsm-testing",
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) can use camera access for optional coach call previews",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) requires microphone access so you can sing during AI vocal coach lessons"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "@clerk/expo",
        {
          "appleSignIn": false
        }
      ],
      "@stream-io/video-react-native-sdk",
      [
        "expo-build-properties",
        { "android": { "minSdkVersion": 24 } }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e84ef483-013c-4dae-bdc9-f03cfb595ece"
      }
    },
    "owner": "juancabral12s-team"
  }
}
