EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stream (getstream.io) — used for audio lesson calls. The API key is public,
# the secret must only ever be read by server code (Expo API routes).
EXPO_PUBLIC_STREAM_API_KEY=...
STREAM_API_SECRET=...

# OpenAI Realtime — used by the Python Vision Agent service in vision-agent/.
OPENAI_API_KEY=...
VISION_AGENT_BASE_URL=http://127.0.0.1:8000

# Google Gemini / Veo — used by server-side lesson video generation only.
GEMINI_API_KEY=...
GEMINI_VEO_MODEL=veo-3.1-generate-preview
LESSON_VIDEO_ADMIN_SECRET=replace-with-a-long-random-value
